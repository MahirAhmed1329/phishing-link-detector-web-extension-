{
  "manifest_version": 3,
  "name": "PhisShield",
  "version": "2.0.0",
  "description": "Professional phishing & malicious URL scanner with VirusTotal-powered risk scores and live pie chart insights.",

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "contextMenus",
    "notifications"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "action": {
    "default_title": "PhisShield — URL Threat Scanner",
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js":  ["utils.js", "content-script.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "phisshield@example.local"
    }
  }
}
